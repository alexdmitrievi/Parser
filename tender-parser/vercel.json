{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "api/tenders.py", "use": "@vercel/python" },
    { "src": "api/debug.py", "use": "@vercel/python" },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/debug", "dest": "/api/debug.py" },
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/search(.*)", "dest": "/api/tenders.py" },
    { "src": "/api/subscriptions(.*)", "dest": "/api/tenders.py" },
    { "src": "/api/tenders(.*)", "dest": "/api/tenders.py" },
    { "src": "/api/stats", "dest": "/api/tenders.py" },
    { "src": "/api/niches", "dest": "/api/tenders.py" },
    { "src": "/api/suggest(.*)", "dest": "/api/tenders.py" },
    { "src": "/api/funding(.*)", "dest": "/api/tenders.py" },
    { "src": "/health", "dest": "/api/tenders.py" },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/web/(.*\\.html)", "headers": { "Cache-Control": "public, max-age=60, s-maxage=300" } },
    { "src": "/web/(.*\\.js)", "headers": { "Cache-Control": "public, max-age=300, s-maxage=600" } },
    { "src": "/web/(.*\\.css)", "headers": { "Cache-Control": "public, max-age=300, s-maxage=600" } },
    { "src": "/web/(.*\\.png)", "headers": { "Cache-Control": "public, max-age=86400, s-maxage=86400" } }
  ]
}
