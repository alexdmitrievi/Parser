# Скопируйте в .env и подставьте свои значения. Не коммитьте .env с реальными секретами.

# Telegram Bot (@BotFather) — обязательно для webhook / polling
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Supabase — Project Settings → API
# URL проекта
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# anon / public key (JWT, обычно начинается с eyJ...)
SUPABASE_KEY=YOUR_ANON_KEY_HERE
# service_role key (JWT) — для GitHub Actions status update, обход RLS; НЕ строка postgresql://
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Опционально: те же данные под другими именами (часть кода читает их)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=

# ЕИС FTP (парсер eis_ftp)
EIS_FTP_HOST=ftp.zakupki.gov.ru

# Опционально: ScrapingBee для JS-heavy площадок
SCRAPING_BEE_API_KEY=

# Опционально: секрет для проверки webhook Telegram
BOT_WEBHOOK_SECRET=

# Логирование
LOG_LEVEL=INFO

# Лимиты бота (подписки)
MAX_FREE_SUBSCRIPTIONS=3
